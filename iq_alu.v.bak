// =============================================================================
// iq_alu.v  —  Issue Queue cho ALU
//
// Payload riêng của ALU:
//   • rs1_val, rs2_val  (Int operands)
//   • imm, pc
//   • alu_op [4:0]
//   • is_branch, is_jal, is_jalr, is_lui, is_auipc
//   • branch_op [2:0]
//   • use_imm
//   • prd, rob_idx
//
// KHÔNG có: fpu_op, lsu_op, rs3, fp_rd, is_load, is_store
//
// CDB snoop: 4 port (ALU-basic, ALU-muldiv, FPU, LSU-load)
//   → chỉ snoop rs1/rs2 (không có rs3)
// =============================================================================

module iq_alu #(
    parameter NUM_RS    = 8,
    parameter TAG_WIDTH = 6,
    parameter ROB_IDX   = 5
)(
    input  wire        clk,
    input  wire        rst_n,
    input  wire        flush,

    // -------------------------------------------------------------------------
    // Write port (từ Dispatch)
    // -------------------------------------------------------------------------
    input  wire                  wr_en,
    input  wire [TAG_WIDTH-1:0]  wr_prd,
    input  wire [TAG_WIDTH-1:0]  wr_prs1,
    input  wire                  wr_prs1_ready,
    input  wire [TAG_WIDTH-1:0]  wr_prs2,
    input  wire                  wr_prs2_ready,
    input  wire [31:0]           wr_imm,
    input  wire [31:0]           wr_pc,
    input  wire [4:0]            wr_alu_op,
    input  wire [ROB_IDX-1:0]   wr_rob_idx,
    input  wire                  wr_use_imm,
    input  wire                  wr_is_branch,
    input  wire                  wr_is_jal,
    input  wire                  wr_is_jalr,
    input  wire                  wr_is_lui,
    input  wire                  wr_is_auipc,
    input  wire [2:0]            wr_branch_op,

    output wire                  full,

    // -------------------------------------------------------------------------
    // CDB (4 port)
    // -------------------------------------------------------------------------
    input  wire [TAG_WIDTH-1:0]  cdb0_tag,
    input  wire                  cdb0_valid,
    input  wire [31:0]           cdb0_data,

    input  wire [TAG_WIDTH-1:0]  cdb1_tag,
    input  wire                  cdb1_valid,
    input  wire [31:0]           cdb1_data,

    input  wire [TAG_WIDTH-1:0]  cdb2_tag,
    input  wire                  cdb2_valid,
    input  wire [31:0]           cdb2_data,

    input  wire [TAG_WIDTH-1:0]  cdb3_tag,
    input  wire                  cdb3_valid,
    input  wire [31:0]           cdb3_data,

    // -------------------------------------------------------------------------
    // PRF read request (combinational — trỏ vào entry sắp issue)
    // -------------------------------------------------------------------------
    output wire [TAG_WIDTH-1:0]  prf_rs1_tag,
    output wire [TAG_WIDTH-1:0]  prf_rs2_tag,
    input  wire [31:0]           prf_rs1_data,
    input  wire [31:0]           prf_rs2_data,

    // -------------------------------------------------------------------------
    // Issue output → ALU EU
    // -------------------------------------------------------------------------
    output reg                   issue_valid,
    output reg  [TAG_WIDTH-1:0]  issue_prd,
    output reg  [ROB_IDX-1:0]   issue_rob_idx,
    output reg  [31:0]           issue_rs1_val,
    output reg  [31:0]           issue_rs2_val,
    output reg  [31:0]           issue_imm,
    output reg  [31:0]           issue_pc,
    output reg  [4:0]            issue_alu_op,
    output reg                   issue_use_imm,
    output reg                   issue_is_branch,
    output reg                   issue_is_jal,
    output reg                   issue_is_jalr,
    output reg                   issue_is_lui,
    output reg                   issue_is_auipc,
    output reg  [2:0]            issue_branch_op
);

    // =========================================================================
    // Storage
    // =========================================================================
    reg                  rs_valid    [0:NUM_RS-1];
    reg [TAG_WIDTH-1:0]  rs_prd      [0:NUM_RS-1];
    reg [TAG_WIDTH-1:0]  rs_prs1     [0:NUM_RS-1];
    reg [TAG_WIDTH-1:0]  rs_prs2     [0:NUM_RS-1];
    reg                  rs_prs1_rdy [0:NUM_RS-1];
    reg                  rs_prs2_rdy [0:NUM_RS-1];
    reg [31:0]           rs_rs1_val  [0:NUM_RS-1];
    reg [31:0]           rs_rs2_val  [0:NUM_RS-1];
    reg [31:0]           rs_imm      [0:NUM_RS-1];
    reg [31:0]           rs_pc       [0:NUM_RS-1];
    reg [4:0]            rs_alu_op   [0:NUM_RS-1];
    reg [ROB_IDX-1:0]   rs_rob_idx  [0:NUM_RS-1];
    reg                  rs_use_imm  [0:NUM_RS-1];
    reg                  rs_is_branch[0:NUM_RS-1];
    reg                  rs_is_jal   [0:NUM_RS-1];
    reg                  rs_is_jalr  [0:NUM_RS-1];
    reg                  rs_is_lui   [0:NUM_RS-1];
    reg                  rs_is_auipc [0:NUM_RS-1];
    reg [2:0]            rs_branch_op[0:NUM_RS-1];
    reg                  rs_age      [0:NUM_RS-1];

    // =========================================================================
    // Free slot (priority encoder)
    // =========================================================================
    integer fi;
    reg [$clog2(NUM_RS)-1:0] free_slot;
    reg found_free;
    always @(*) begin
        free_slot  = 0;
        found_free = 1'b0;
        for (fi = NUM_RS-1; fi >= 0; fi = fi - 1)
            if (!rs_valid[fi]) begin free_slot = fi[$clog2(NUM_RS)-1:0]; found_free = 1'b1; end
    end
    assign full = !found_free;

    // =========================================================================
    // Issue selection (oldest-first)
    // =========================================================================
    integer si;
    reg [$clog2(NUM_RS)-1:0] issue_slot;
    reg found_issue;
    always @(*) begin
        issue_slot  = 0;
        found_issue = 1'b0;
        for (si = 0; si < NUM_RS; si = si + 1)
            if (rs_valid[si] && rs_prs1_rdy[si] && rs_prs2_rdy[si]) begin
                if (!found_issue || rs_age[si]) begin
                    issue_slot  = si[$clog2(NUM_RS)-1:0];
                    found_issue = 1'b1;
                end
            end
    end

    assign prf_rs1_tag = rs_prs1[issue_slot];
    assign prf_rs2_tag = rs_prs2[issue_slot];

    // =========================================================================
    // CDB snoop helper
    // =========================================================================
    // Macro-like task không được dùng trong generate; dùng inline
    // =========================================================================

    integer i;
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n || flush) begin
            issue_valid <= 1'b0;
            for (i = 0; i < NUM_RS; i = i + 1) begin
                rs_valid[i] <= 1'b0;
                rs_age[i]   <= 1'b0;
            end
        end else begin
            issue_valid <= 1'b0;

            // ------------------------------------------------------------------
            // 1. CDB Snoop
            // ------------------------------------------------------------------
            for (i = 0; i < NUM_RS; i = i + 1) begin
                if (rs_valid[i]) begin
                    if (cdb0_valid) begin
                        if (!rs_prs1_rdy[i] && rs_prs1[i] == cdb0_tag)
                            begin rs_prs1_rdy[i] <= 1'b1; rs_rs1_val[i] <= cdb0_data; end
                        if (!rs_prs2_rdy[i] && rs_prs2[i] == cdb0_tag)
                            begin rs_prs2_rdy[i] <= 1'b1; rs_rs2_val[i] <= cdb0_data; end
                    end
                    if (cdb1_valid) begin
                        if (!rs_prs1_rdy[i] && rs_prs1[i] == cdb1_tag)
                            begin rs_prs1_rdy[i] <= 1'b1; rs_rs1_val[i] <= cdb1_data; end
                        if (!rs_prs2_rdy[i] && rs_prs2[i] == cdb1_tag)
                            begin rs_prs2_rdy[i] <= 1'b1; rs_rs2_val[i] <= cdb1_data; end
                    end
                    if (cdb2_valid) begin
                        if (!rs_prs1_rdy[i] && rs_prs1[i] == cdb2_tag)
                            begin rs_prs1_rdy[i] <= 1'b1; rs_rs1_val[i] <= cdb2_data; end
                        if (!rs_prs2_rdy[i] && rs_prs2[i] == cdb2_tag)
                            begin rs_prs2_rdy[i] <= 1'b1; rs_rs2_val[i] <= cdb2_data; end
                    end
                    if (cdb3_valid) begin
                        if (!rs_prs1_rdy[i] && rs_prs1[i] == cdb3_tag)
                            begin rs_prs1_rdy[i] <= 1'b1; rs_rs1_val[i] <= cdb3_data; end
                        if (!rs_prs2_rdy[i] && rs_prs2[i] == cdb3_tag)
                            begin rs_prs2_rdy[i] <= 1'b1; rs_rs2_val[i] <= cdb3_data; end
                    end
                end
            end

            // ------------------------------------------------------------------
            // 2. Write
            // ------------------------------------------------------------------
            if (wr_en && !full) begin
                rs_valid[free_slot]     <= 1'b1;
                rs_prd[free_slot]       <= wr_prd;
                rs_prs1[free_slot]      <= wr_prs1;
                rs_prs2[free_slot]      <= wr_prs2;
                rs_prs1_rdy[free_slot]  <= wr_prs1_ready;
                rs_prs2_rdy[free_slot]  <= wr_prs2_ready;
                rs_rs1_val[free_slot]   <= 32'd0;
                rs_rs2_val[free_slot]   <= 32'd0;
                rs_imm[free_slot]       <= wr_imm;
                rs_pc[free_slot]        <= wr_pc;
                rs_alu_op[free_slot]    <= wr_alu_op;
                rs_rob_idx[free_slot]   <= wr_rob_idx;
                rs_use_imm[free_slot]   <= wr_use_imm;
                rs_is_branch[free_slot] <= wr_is_branch;
                rs_is_jal[free_slot]    <= wr_is_jal;
                rs_is_jalr[free_slot]   <= wr_is_jalr;
                rs_is_lui[free_slot]    <= wr_is_lui;
                rs_is_auipc[free_slot]  <= wr_is_auipc;
                rs_branch_op[free_slot] <= wr_branch_op;
                rs_age[free_slot]       <= 1'b0;
                for (i = 0; i < NUM_RS; i = i + 1)
                    if (rs_valid[i] && i != free_slot) rs_age[i] <= 1'b1;
            end

            // ------------------------------------------------------------------
            // 3. Issue
            // ------------------------------------------------------------------
            if (found_issue) begin
                issue_valid     <= 1'b1;
                issue_prd       <= rs_prd[issue_slot];
                issue_rob_idx   <= rs_rob_idx[issue_slot];
                issue_rs1_val   <= rs_prs1_rdy[issue_slot] ? rs_rs1_val[issue_slot] : prf_rs1_data;
                issue_rs2_val   <= rs_prs2_rdy[issue_slot] ? rs_rs2_val[issue_slot] : prf_rs2_data;
                issue_imm       <= rs_imm[issue_slot];
                issue_pc        <= rs_pc[issue_slot];
                issue_alu_op    <= rs_alu_op[issue_slot];
                issue_use_imm   <= rs_use_imm[issue_slot];
                issue_is_branch <= rs_is_branch[issue_slot];
                issue_is_jal    <= rs_is_jal[issue_slot];
                issue_is_jalr   <= rs_is_jalr[issue_slot];
                issue_is_lui    <= rs_is_lui[issue_slot];
                issue_is_auipc  <= rs_is_auipc[issue_slot];
                issue_branch_op <= rs_branch_op[issue_slot];
                rs_valid[issue_slot] <= 1'b0;
            end
        end
    end

endmodule