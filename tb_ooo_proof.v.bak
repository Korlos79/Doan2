// =============================================================================
// tb_ooo_proof.v  —  Testbench chứng minh Out-of-Order Execution
//
// Chiến lược chứng minh OOO:
// ─────────────────────────────────────────────────────────────────────────────
//  Dùng chuỗi lệnh được thiết kế đặc biệt:
//
//  I0: MUL  x3, x1, x2     → ALU MUL (multi-cycle ~32 cycles), ghi x3
//  I1: ADD  x5, x4, x4     → ALU ADD (1 cycle), không phụ thuộc I0
//  I2: ADD  x6, x4, x4     → ALU ADD (1 cycle), không phụ thuộc I0
//  I3: ADD  x7, x5, x6     → phụ thuộc I1+I2, vào IQ đợi
//  I4: ADD  x8, x3, x1     → phụ thuộc I0 (MUL), phải đợi MUL xong
//
//  Kỳ vọng OOO:
//   • I1, I2 issue và writeback TRƯỚC I0 (MUL chưa xong)
//   • I3 issue ngay sau I1+I2 sẵn sàng (CDB wakeup)
//   • I0 (MUL) writeback muộn → I4 issue sau I0
//   • ROB commit theo thứ tự: I0, I1, I2, I3, I4 (in-order commit)
//     nhưng writeback xảy ra theo thứ tự: I1, I2, I3, I0, I4
//
//  Probe điểm chứng minh:
//   - wb0_valid (ALU basic WB): bắt lúc I1/I2 ghi kết quả
//   - wb1_valid (MUL/DIV WB) : bắt lúc I0 ghi kết quả (muộn hơn I1/I2)
//   - rob commit_valid + commit_rd_arch: xác nhận commit theo đúng thứ tự
//   - $display log timing từng lệnh
// =============================================================================

`timescale 1ns/1ps

module tb_ooo_proof;

    // =========================================================================
    // Clock & Reset
    // =========================================================================
    reg clk  = 0;
    reg rst_n = 0;
    always #5 clk = ~clk;   // 100 MHz

    // =========================================================================
    // DUT
    // =========================================================================
    rv32ifm_ooo #(
        .TAG_WIDTH (6),
        .ROB_IDX   (5),
        .ROB_DEPTH (32),
        .NUM_PHYS  (64),
        .NUM_ARCH  (32)
    ) dut (
        .clk   (clk),
        .rst_n (rst_n)
    );

    // =========================================================================
    // Cycle counter
    // =========================================================================
    integer cyc = 0;
    always @(posedge clk) cyc = cyc + 1;

    // =========================================================================
    // Capture writeback events — chứng minh OOO
    // =========================================================================

    // --- WB0: ALU Basic (1-cycle) ---
    always @(posedge clk) begin
        if (dut.u_alu_eu.wb0_valid) begin
            $display("[CYC %0d] WB0 ALU-basic  rob_idx=%0d  prd=p%0d  result=0x%08h  exc=%b",
                     cyc,
                     dut.u_alu_eu.wb0_rob_idx,
                     dut.u_alu_eu.wb0_prd,
                     dut.u_alu_eu.wb0_result,
                     dut.u_alu_eu.wb0_exc);
        end
    end

    // --- WB1: MUL/DIV (multi-cycle) ---
    always @(posedge clk) begin
        if (dut.u_alu_eu.wb1_valid) begin
            $display("[CYC %0d] WB1 MUL/DIV    rob_idx=%0d  prd=p%0d  result=0x%08h  *** LATE ***",
                     cyc,
                     dut.u_alu_eu.wb1_rob_idx,
                     dut.u_alu_eu.wb1_prd,
                     dut.u_alu_eu.wb1_result);
        end
    end

    // --- WB2: FPU ---
    always @(posedge clk) begin
        if (dut.u_fpu_eu.wb2_valid) begin
            $display("[CYC %0d] WB2 FPU        rob_idx=%0d  prd=p%0d  result=0x%08h",
                     cyc,
                     dut.u_fpu_eu.wb2_rob_idx,
                     dut.u_fpu_eu.wb2_prd,
                     dut.u_fpu_eu.wb2_result);
        end
    end

    // --- WB3: LSU Load ---
    always @(posedge clk) begin
        if (dut.u_lsu_eu.wb3_valid) begin
            $display("[CYC %0d] WB3 LOAD       rob_idx=%0d  prd=p%0d  result=0x%08h",
                     cyc,
                     dut.u_lsu_eu.wb3_rob_idx,
                     dut.u_lsu_eu.wb3_prd,
                     dut.u_lsu_eu.wb3_result);
        end
    end

    // =========================================================================
    // Capture ROB commit — chứng minh in-order commit
    // =========================================================================
    always @(posedge clk) begin
        if (dut.u_rob.commit_valid) begin
            $display("[CYC %0d] COMMIT  rd=x%0d  prd=p%0d  result=0x%08h  fp=%b  store=%b",
                     cyc,
                     dut.u_rob.commit_rd_arch,
                     dut.u_rob.commit_prd,
                     dut.u_rob.commit_result,
                     dut.u_rob.commit_fp_rd,
                     dut.u_rob.commit_store);
        end
    end

    // =========================================================================
    // Capture IQ issue — thấy thứ tự issue OOO
    // =========================================================================
    always @(posedge clk) begin
        if (dut.u_iq_alu.issue_valid) begin
            $display("[CYC %0d] IQ_ALU ISSUE  rob_idx=%0d  prd=p%0d  alu_op=0x%02h  rs1=0x%08h  rs2=0x%08h  use_imm=%b",
                     cyc,
                     dut.u_iq_alu.issue_rob_idx,
                     dut.u_iq_alu.issue_prd,
                     dut.u_iq_alu.issue_alu_op,
                     dut.u_iq_alu.issue_rs1_val,
                     dut.u_iq_alu.issue_rs2_val,
                     dut.u_iq_alu.issue_use_imm);
        end
    end

    // =========================================================================
    // Capture dispatch → ROB alloc
    // =========================================================================
    always @(posedge clk) begin
        if (dut.u_rob.alloc_valid) begin
            $display("[CYC %0d] DISPATCH→ROB  rob_idx=%0d  rd=x%0d  prd=p%0d  is_branch=%b  is_store=%b",
                     cyc,
                     dut.u_rob.rob_idx,
                     dut.u_rob.alloc_rd_arch,
                     dut.u_rob.alloc_prd,
                     dut.u_rob.alloc_is_branch,
                     dut.u_rob.alloc_is_store);
        end
    end

    // =========================================================================
    // Capture flush
    // =========================================================================
    always @(posedge clk) begin
        if (dut.u_rob.flush) begin
            $display("[CYC %0d] *** FLUSH  flush_pc=0x%08h ***", cyc, dut.u_rob.flush_pc);
        end
    end

    // =========================================================================
    // Lấy giá trị PRF (physical register) sau commit để kiểm tra đúng sai
    // =========================================================================
    // Sau khi commit tất cả 5 lệnh, đọc prf để xác nhận
    // x1=10, x2=3, x4=5
    // I0: x3 = x1*x2 = 30      (MUL)
    // I1: x5 = x4+x4 = 10      (ADD)
    // I2: x6 = x4+x4 = 10      (ADD)
    // I3: x7 = x5+x6 = 20      (ADD)
    // I4: x8 = x3+x1 = 30+10 = 40  (ADD)

    // =========================================================================
    // Main stimulus
    // =========================================================================
    integer i;
    integer ooo_proven = 0;   // flag: đã thấy ADD writeback trước MUL writeback
    integer add_wb_cycle = -1;
    integer mul_wb_cycle = -1;

    // Track first ADD WB và MUL WB cycle
    always @(posedge clk) begin
        if (dut.u_alu_eu.wb0_valid && add_wb_cycle < 0)
            add_wb_cycle = cyc;
        if (dut.u_alu_eu.wb1_valid && mul_wb_cycle < 0)
            mul_wb_cycle = cyc;
    end

    initial begin
        $dumpfile("tb_ooo_proof.vcd");
        $dumpvars(0, tb_ooo_proof);

        // ─── Reset ───────────────────────────────────────────────────────────
        rst_n = 0;
        repeat(4) @(posedge clk);
        #1 rst_n = 1;

        $display("=======================================================");
        $display(" OOO PROOF TESTBENCH  —  rv32ifm_ooo");
        $display("=======================================================");
        $display("Sequence:");
        $display("  I0 @ 0x00: MUL  x3,  x1, x2   (multi-cycle ~32 cyc)");
        $display("  I1 @ 0x04: ADD  x5,  x4, x4   (1 cycle)");
        $display("  I2 @ 0x08: ADD  x6,  x4, x4   (1 cycle)");
        $display("  I3 @ 0x0C: ADD  x7,  x5, x6   (depends I1,I2)");
        $display("  I4 @ 0x10: ADD  x8,  x3, x1   (depends I0 MUL)");
        $display("  I5 @ 0x14: ADD  x9,  x7, x4   (depends I3)");
        $display("  I6 @ 0x18: ADD  x10, x8, x4   (depends I4)");
        $display("  (x1=10, x2=3, x4=5 set via ADDI at startup)");
        $display("=======================================================");
        $display("Expected OOO proof:");
        $display("  ADD WB (I1/I2) xảy ra TRƯỚC MUL WB (I0)");
        $display("  ROB commit vẫn theo thứ tự I0→I1→I2→...");
        $display("=======================================================");
        $display("");

        // ─── Chạy đủ lâu để thấy toàn bộ pipeline ───────────────────────────
        // MUL latency ~32 cycles + pipeline stages + margins
        repeat(150) @(posedge clk);

        // ─── Kết quả ─────────────────────────────────────────────────────────
        $display("");
        $display("=======================================================");
        $display(" RESULT SUMMARY");
        $display("=======================================================");

        if (add_wb_cycle >= 0 && mul_wb_cycle >= 0) begin
            $display("  First ADD writeback : cycle %0d", add_wb_cycle);
            $display("  First MUL writeback : cycle %0d", mul_wb_cycle);
            if (add_wb_cycle < mul_wb_cycle) begin
                $display("  >>> OOO PROVEN: ADD WB (cyc %0d) < MUL WB (cyc %0d) <<<",
                         add_wb_cycle, mul_wb_cycle);
                $display("  Lệnh I1/I2 (không phụ thuộc MUL) đã bypass I0 (MUL)");
                $display("  và writeback sớm hơn — đúng OOO behavior.");
            end else begin
                $display("  [!] ADD WB không sớm hơn MUL WB — kiểm tra lại IQ scheduling");
            end
        end else begin
            $display("  [!] Chưa thấy cả hai WB events trong %0d cycles", cyc);
        end

        // ─── Kiểm tra giá trị PRF cuối cùng ─────────────────────────────────
        // Đọc trực tiếp từ prf array của DUT sau khi mọi lệnh commit
        // (architectural registers x1..x10)
        $display("");
        $display("  PRF check (physical reg data, vị trí arch->phys qua RAT):");
        $display("  Xem waveform hoặc log COMMIT để xác nhận giá trị.");
        $display("=======================================================");

        #10 $finish;
    end

    // =========================================================================
    // Timeout watchdog
    // =========================================================================
    initial begin
        #20000;
        $display("[TIMEOUT] Simulation exceeded 20000 ns");
        $finish;
    end

endmodule