module iter_mul32 (
    input  wire        clk,
    input  wire        rst_n,

    input  wire        start,       // Tín hiệu valid đầu vào
    input  wire [4:0]  op_sel,      // 10000->10011

    input  wire [31:0] rs1,
    input  wire [31:0] rs2,

    output wire        busy,        
    output reg         done,        // Valid đầu ra (Đã sửa thành Pulse)
    output reg  [31:0] result
);

    // Opcodes Definition
    localparam OP_MUL    = 5'b10000;
    localparam OP_MULH   = 5'b10001;
    localparam OP_MULHSU = 5'b10010;
    localparam OP_MULHU  = 5'b10011;

    assign busy = 1'b0; 

    // =========================================================================
    // STAGE 1: DECODE & ABSOLUTE VALUE
    // =========================================================================
    reg        s1_valid;
    reg        s1_want_high;
    reg        s1_neg_res;
    reg [31:0] s1_abs_a;
    reg [31:0] s1_abs_b;
    
    // Sử dụng wire cho logic tổ hợp bên trong always
    wire is_a_signed_w = (op_sel == OP_MULH) | (op_sel == OP_MULHSU);
    wire is_b_signed_w = (op_sel == OP_MULH);

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            s1_valid <= 0;
            s1_want_high <= 0; s1_neg_res <= 0; s1_abs_a <= 0; s1_abs_b <= 0;
        end else begin
            s1_valid <= start;
            s1_want_high <= (op_sel != OP_MUL);

            if (is_a_signed_w && rs1[31]) s1_abs_a <= (~rs1 + 1);
            else                          s1_abs_a <= rs1;

            if (is_b_signed_w && rs2[31]) s1_abs_b <= (~rs2 + 1);
            else                          s1_abs_b <= rs2;

            s1_neg_res <= (is_a_signed_w & rs1[31]) ^ (is_b_signed_w & rs2[31]);
        end
    end

    // =========================================================================
    // STAGE 2: MULTIPLICATION PART 1
    // =========================================================================
    reg        s2_valid;
    reg        s2_want_high;
    reg        s2_neg_res;
    reg [63:0] s2_product_raw;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            s2_valid <= 0;
            s2_want_high <= 0; s2_neg_res <= 0; s2_product_raw <= 0;
        end else begin
            s2_valid <= s1_valid;
            s2_want_high <= s1_want_high;
            s2_neg_res   <= s1_neg_res;
            s2_product_raw <= s1_abs_a * s1_abs_b;
        end
    end

    // =========================================================================
    // STAGE 3: BUFFER / DELAY
    // =========================================================================
    reg        s3_valid;
    reg        s3_want_high;
    reg        s3_neg_res;
    reg [63:0] s3_product;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            s3_valid <= 0;
            s3_want_high <= 0; s3_neg_res <= 0; s3_product <= 0;
        end else begin
            s3_valid <= s2_valid;
            s3_want_high <= s2_want_high;
            s3_neg_res   <= s2_neg_res;
            s3_product   <= s2_product_raw;
        end
    end

    // =========================================================================
    // STAGE 4: FINALIZE (SỬA ĐỂ DONE CHỈ LÊN 1 CHU KỲ)
    // =========================================================================
    reg [63:0] final_product;
    reg        s3_valid_prev; // Thanh ghi phụ để bắt cạnh lên của valid

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            done <= 0;
            result <= 0;
            s3_valid_prev <= 0;
        end else begin
            s3_valid_prev <= s3_valid;

            // Logic Done: Chỉ lên 1 chu kỳ khi thấy s3_valid chuyển từ 0 -> 1
            // Điều này giải quyết triệt để việc 'start' bị giữ lâu ở đầu vào
            if (s3_valid && !s3_valid_prev) begin
                done <= 1'b1;
            end else begin
                done <= 1'b0;
            end

            // 1. Áp lại dấu
            if (s3_neg_res) 
                final_product = ~s3_product + 64'd1;
            else 
                final_product = s3_product;

            // 2. Chọn Low/High
            if (s3_want_high)
                result <= final_product[63:32];
            else
                result <= final_product[31:0];
        end
    end

endmodule