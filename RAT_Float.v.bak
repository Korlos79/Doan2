module RAT_Float #(
    parameter TAG_WIDTH = 4
)(
    input wire clk,
    input wire rst_n,

    // =========================================
    // 1. CỔNG ĐỌC (Hỏi thông tin f1, f2, f3)
    // =========================================
    input  wire [4:0]           rs1_addr,
    output wire                 rs1_ready,
    output wire [TAG_WIDTH-1:0] rs1_tag,

    input  wire [4:0]           rs2_addr,
    output wire                 rs2_ready,
    output wire [TAG_WIDTH-1:0] rs2_tag,

    // Thêm cổng đọc thứ 3 cho FMA
    input  wire [4:0]           rs3_addr,
    output wire                 rs3_ready,
    output wire [TAG_WIDTH-1:0] rs3_tag,

    // =========================================
    // 2. CỔNG ISSUE
    // =========================================
    input  wire                 issue_valid,
    input  wire [4:0]           issue_rd,
    input  wire [TAG_WIDTH-1:0] issue_rob_tag,

    // =========================================
    // 3. CỔNG COMMIT 
    // =========================================
    input  wire                 commit_valid,
    input  wire [4:0]           commit_rd,
    input  wire [TAG_WIDTH-1:0] commit_tag
);

    reg [31:0] valid; 
    reg [TAG_WIDTH-1:0] tag_table [31:0];

    // Lõi logic đọc: Không chặn bất cứ cái gì
    assign rs1_ready = valid[rs1_addr];
    assign rs1_tag   = tag_table[rs1_addr];

    assign rs2_ready = valid[rs2_addr];
    assign rs2_tag   = tag_table[rs2_addr];

    assign rs3_ready = valid[rs3_addr];
    assign rs3_tag   = tag_table[rs3_addr];

    integer i;
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            valid <= 32'hFFFFFFFF;
            for (i=0; i<32; i=i+1) tag_table[i] <= 0;
        end else begin
            // A. DỌN DẸP KHI COMMIT (f0 vẫn được dọn)
            if (commit_valid) begin
                if (tag_table[commit_rd] == commit_tag) begin
                    valid[commit_rd] <= 1'b1;
                end
            end

            // B. GHI ĐỔI TÊN KHI ISSUE (f0 vẫn được đổi tên)
            if (issue_valid) begin
                valid[issue_rd]     <= 1'b0;
                tag_table[issue_rd] <= issue_rob_tag;
            end
        end
    end
endmodule